# ─────────────────────────────────────────────
# Trippy — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:5173

# Production: set to your actual domain
# FRONTEND_URL=https://trippy.yourdomain.com

# ── Session ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Database ─────────────────────────────────
# Path to SQLite file — will be created on first run
DB_PATH=./data/trippy.db

# ── Anthropic (Claude API) ───────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# ── Unsplash ─────────────────────────────────
# Get from: https://unsplash.com/developers (free tier: 50 req/hr)
# Register app → copy "Access Key"
UNSPLASH_ACCESS_KEY=REPLACE_WITH_YOUR_UNSPLASH_ACCESS_KEY

# ── Google Places ────────────────────────────
# Get from: https://console.cloud.google.com
# Enable: Places API (New)
# Restrict key to: Places API, your domain/IP
GOOGLE_PLACES_API_KEY=REPLACE_WITH_YOUR_GOOGLE_PLACES_KEY

# AeroDataBox / RapidAPI - optional flight schedule autofill
# Get from: https://rapid.aerodatabox.com/
# Subscribe to the Basic / Free plan, then copy the headers from RapidAPI's endpoint playground.
FLIGHT_DATA_PROVIDER=aerodatabox
AERODATABOX_API_KEY=REPLACE_WITH_YOUR_RAPIDAPI_KEY
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com

# ── MapTiler (optional — OSM fallback maps) ──
# Get from: https://cloud.maptiler.com (free tier available)
# Used for non-China map tiles. Leave blank to use OpenStreetMap directly.
MAPTILER_API_KEY=REPLACE_WITH_YOUR_MAPTILER_KEY

# ── Docker / Production only ─────────────────
# HTTPS is required for PWA install + secure cookies
# Set these when deploying behind nginx/caddy
# COOKIE_SECURE=true
# COOKIE_DOMAIN=trippy.yourdomain.com
